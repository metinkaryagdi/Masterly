{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=training_platform;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "TrainingPlatform",
    "Audience": "TrainingPlatform.Client",
    "SecretKey": "change-this-development-secret-key-please",
    "ExpiryMinutes": 120
  },
  "AI": {
    "Ollama": {
      "Enabled": false,
      "BaseUrl": "http://localhost:11434",
      "Model": "llama3.1",
      "TimeoutSeconds": 60
    }
  },
  "Execution": {
    "Runner": {
      "Enabled": false,
      "BaseUrl": "http://localhost:5055",
      "TimeoutSeconds": 90
    }
  },
  "AllowedHosts": "*"
}
